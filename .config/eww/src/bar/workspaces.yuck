(deflisten workspaces_data
  :initial '[{"id":1,"state":"empty"}]'
  "bash ~/.config/eww/scripts/bar/workspaces.sh")

(defwidget widget_workspaces []
  (box :orientation "h"
       :space-evenly false
       :spacing 10
       :valign "center"
    (for ws in {workspaces_data}
      (eventbox :cursor "pointer"
        (button :class "ws-pill ${ws.state}"
                :onclick "hyprctl dispatch workspace ${ws.id}"
                )))
  )
)
