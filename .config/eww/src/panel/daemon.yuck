(defpoll power_profile
  :interval "60m" "powerprofilesctl get")

(defwidget widget_daemon []
  (box :class "daemon-card ${power_profile}"
       :orientation "horizontal"
       :space-evenly false

       (eventbox :cursor "pointer"
                 :hexpand true
                 (button :class "left-action"
                         :onclick "bash ~/.config/eww/scripts/panel/daemon_toggle.sh &"

                         (box :orientation "horizontal"
                              :space-evenly false
                              :spacing 14
                              :valign "center"

                              (label :class "daemon-icon"
                                     :text {power_profile == "performance" ? "" :
                                     power_profile == "power-saver" ? "" : "󰶘"})

                              (box :orientation "vertical"
                                   :space-evenly false
                                   :spacing 2
                                   :valign "center"
                                   (label :class "title"
                                          :text "Power Mode")
                                   (label :class "mode"
                                          :text {power_profile == "performance" ? "Performance" :
                                          power_profile == "power-saver" ? "Power Saver" : "Balanced"}))))
                 )
       )
  )

